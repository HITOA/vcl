#ifndef TOK
    #define TOK(x)
#endif
#ifndef PUNCTUATOR
    #define PUNCTUATOR(x, y) TOK(x)
#endif
#ifndef KEYWORD
    #define KEYWORD(x) TOK(Keyword_##x)
#endif

TOK(Unknown)
TOK(EndOfFile)
TOK(Comment)
TOK(Identifier)
TOK(NumericConstant)
TOK(StringLiteral)

PUNCTUATOR(Semicolon,               ";")
PUNCTUATOR(LeftPar,                 "(")
PUNCTUATOR(RightPar,                ")")
PUNCTUATOR(LeftSquare,              "[")
PUNCTUATOR(RightSquare,             "]")
PUNCTUATOR(LeftBrace,               "{")
PUNCTUATOR(RightBrace,              "}")
PUNCTUATOR(Period,                  ".")
PUNCTUATOR(Coma,                    ",")
PUNCTUATOR(At,                      "@")
PUNCTUATOR(Asterisk,                "*")
PUNCTUATOR(Slash,                   "/")
PUNCTUATOR(Percent,                 "%")
PUNCTUATOR(Plus,                    "+")
PUNCTUATOR(Minus,                   "-")
PUNCTUATOR(Greater,                 ">")
PUNCTUATOR(Lesser,                  "<")
PUNCTUATOR(Exclaim,                 "!")
PUNCTUATOR(Equal,                   "=")
PUNCTUATOR(Amp,                     "&")
PUNCTUATOR(Pipe,                    "|")
PUNCTUATOR(Caret,                   "^")
PUNCTUATOR(Tilde,                   "~")
PUNCTUATOR(PlusEqual,               "+=")
PUNCTUATOR(MinusEqual,              "-=")
PUNCTUATOR(AsteriskEqual,           "*=")
PUNCTUATOR(SlashEqual,              "/=")
PUNCTUATOR(PercentEqual,            "%=")
PUNCTUATOR(AmpEqual,                "&=")
PUNCTUATOR(PipeEqual,               "|=")
PUNCTUATOR(CaretEqual,              "^=")
PUNCTUATOR(GreaterEqual,            ">=")
PUNCTUATOR(LesserEqual,             "<=")
PUNCTUATOR(EqualEqual,              "==")
PUNCTUATOR(ExclaimEqual,            "!=")
PUNCTUATOR(AmpAmp,                  "&&")
PUNCTUATOR(PipePipe,                "||")
PUNCTUATOR(PlusPlus,                "++")
PUNCTUATOR(MinusMinus,              "--")
PUNCTUATOR(GreaterGreater,          ">>")
PUNCTUATOR(LesserLesser,            "<<")
PUNCTUATOR(ColonColon,              "::")
PUNCTUATOR(GreaterGreaterEqual,     ">>=")
PUNCTUATOR(LesserLesserEqual,       "<<=")

KEYWORD(return)
KEYWORD(if)
KEYWORD(else)
KEYWORD(while)
KEYWORD(for)
KEYWORD(break)
KEYWORD(continue)
KEYWORD(struct)
KEYWORD(template)
KEYWORD(typename)
KEYWORD(export)

// Type Qualifiers

KEYWORD(in)
KEYWORD(out)
KEYWORD(inout)
KEYWORD(const)

// Type

KEYWORD(Vec)
KEYWORD(Array)
KEYWORD(Span)
KEYWORD(Delegate)

KEYWORD(float32)
KEYWORD(float64)
KEYWORD(int8)
KEYWORD(int16)
KEYWORD(int32)
KEYWORD(int64)
KEYWORD(uint8)
KEYWORD(uint16)
KEYWORD(uint32)
KEYWORD(uint64)
KEYWORD(bool)
KEYWORD(void)

#undef TOK
#undef PUNCTUATOR
#undef KEYWORD