#ifndef DIAGNOSTIC
    #define DIAGNOSTIC(x, y)
#endif
#ifndef DIAGNOSTIC_HINT
    #define DIAGNOSTIC_HINT(x, y)
#endif
#ifndef SOURCE_DIAGNOSTIC
    #define SOURCE_DIAGNOSTIC(x, y) DIAGNOSTIC(x, y)
#endif
#ifndef LEXER_DIAGNOSTIC
    #define LEXER_DIAGNOSTIC(x, y) DIAGNOSTIC(x, y)
#endif
#ifndef PARSER_DIAGNOSTIC
    #define PARSER_DIAGNOSTIC(x, y) DIAGNOSTIC(x, y)
#endif
#ifndef SEMA_DIAGNOSTIC
    #define SEMA_DIAGNOSTIC(x, y) DIAGNOSTIC(x, y)
#endif

DIAGNOSTIC_HINT(PreviouslyDeclared,              "previously declared here")
DIAGNOSTIC_HINT(Declared,                        "declared here")

DIAGNOSTIC(MissingImplementation,                "missing implementation")
DIAGNOSTIC(InternalError,                        "internal compiler error")

SOURCE_DIAGNOSTIC(FileNotFound,                  "could not open '%0'; file not found")
SOURCE_DIAGNOSTIC(MemoryBufferCreationFailed,    "memory buffer creation failed")

LEXER_DIAGNOSTIC(InvalidCharacter,               "'%0' is an invalid character")
LEXER_DIAGNOSTIC(UnterminatedString,             "'%0' is an unterminated string")
LEXER_DIAGNOSTIC(NumericConstantTooMuchText,     "'%0' has too much text after expected end of numeric constant")

PARSER_DIAGNOSTIC(UnexpectedToken,               "unexpected token '%0'")
PARSER_DIAGNOSTIC(UnexpectedTokenAfter,          "unexpected token '%0' after '%1'")
PARSER_DIAGNOSTIC(WrongTemplateArgument,         "wrong template argument")
PARSER_DIAGNOSTIC(WrongTemplateParameter,        "wrong template parameter")
PARSER_DIAGNOSTIC(FloatTemplateArgument,         "numeric constant template argument cannot be float")

SEMA_DIAGNOSTIC(Redeclaration,                   "redeclaration of '%0'")
SEMA_DIAGNOSTIC(ReservedIdentifier,              "'%0' is a reserved identifier")
SEMA_DIAGNOSTIC(TooManyTemplateArgument,         "too many template arguments")
SEMA_DIAGNOSTIC(NotEnoughTemplateArgument,       "not enough template arguments")
SEMA_DIAGNOSTIC(MissingTemplateArgument,         "missing template argument for '%0'")
SEMA_DIAGNOSTIC(TemplateArgumentWrongType,       "wrong type of template argument")
SEMA_DIAGNOSTIC(BuiltinTypeIsNotTemplated,       "builtin type '%0' is not templated")
SEMA_DIAGNOSTIC(IdentifierUndefined,             "identifier '%0' is undefined")
SEMA_DIAGNOSTIC(InvalidCast,                     "invalid cast from type '%0' to type '%1'")
SEMA_DIAGNOSTIC(InvalidVectorCast,               "cannot cast vector type '%0' to non vector type '%1'")
SEMA_DIAGNOSTIC(InvalidSplat,                    "invalid broadcasting of '%0'")
SEMA_DIAGNOSTIC(DoesNotTakeTemplateArgList,      "'%0' does not take a template argument list")
SEMA_DIAGNOSTIC(NotTypeDecl,                     "'%0' is not a type declaration")
SEMA_DIAGNOSTIC(TemplateRedeclared,              "template parameter '%0' cannot be redeclared in this scope")
SEMA_DIAGNOSTIC(ExprDoesNotEvaluate,             "expression does not evaluate at compile time")
SEMA_DIAGNOSTIC(ExprDoesNotEvaluateScalar,       "expression does not evaluate at compile time to a scalar")
SEMA_DIAGNOSTIC(AttrInvalidUse,                  "invalid use of global variable attributes on a local variable")
SEMA_DIAGNOSTIC(InitializerInputVarDecl,         "external input variable declaration cannot have a initializer")
SEMA_DIAGNOSTIC(AssignmentNotLValue,             "left-hand side of assignment must be a variable or a memory location (l-value)")
SEMA_DIAGNOSTIC(AssignmentConstValue,            "cannot assign to a variable that is const")
SEMA_DIAGNOSTIC(AssignmentInputValue,            "cannot assign to an input variable")
SEMA_DIAGNOSTIC(ReturnStmtOutsideOfBody,         "return statement cannot be outside of a function's body")
SEMA_DIAGNOSTIC(MissingReturnStmt,               "missing return statement for non-void function")
SEMA_DIAGNOSTIC(InvalidReturnStmtNoExpr,         "invalid return statement missing expression for non-void function")
SEMA_DIAGNOSTIC(InvalidReturnStmtExpr,           "invalid return statement having an expression for void function")
SEMA_DIAGNOSTIC(StatementNeverReached,           "statement will never be reached")
SEMA_DIAGNOSTIC(TooManyArgument,                 "too many arguments")
SEMA_DIAGNOSTIC(MissingArgument,                 "missing arguments")
SEMA_DIAGNOSTIC(MustBeLValue,                    "expression must be a l-value")
SEMA_DIAGNOSTIC(IncorrectType,                   "expression is of incorrect type '%0' when '%1' is expected")
SEMA_DIAGNOSTIC(NotIntegralType,                 "expression must have integral type but have '%0'")
SEMA_DIAGNOSTIC(NotNumericType,                  "expression must have numeric type but have '%0'")
SEMA_DIAGNOSTIC(MustHaveStructType,              "expression must have a struct type but have '%0'")
SEMA_DIAGNOSTIC(MustBeSubscriptable,             "expression must be subscriptable")
SEMA_DIAGNOSTIC(QualifierDropped,                "qualifiers dropped from '%0' to '%1'")
SEMA_DIAGNOSTIC(MissingMember,                   "struct '%0' has no member '%0'")
SEMA_DIAGNOSTIC(InvalidAggregateType,            "aggregate expression must either be of array type or record type but is '%0'")
SEMA_DIAGNOSTIC(TooManyInitializerValue,         "too many initializer value")
SEMA_DIAGNOSTIC(InvalidArithmeticConversion,     "type '%0' is not a valid for arithmetic conversion")
SEMA_DIAGNOSTIC(LoseOfFloatingPointPrecision,    "implicit conversion loses floating-point precision: '%0' to '%1'")
SEMA_DIAGNOSTIC(LoseOfIntegerPrecision,          "implicit conversion loses integer precision: '%0' to '%1'")

#undef DIAGNOSTIC_HINT
#undef SEMA_DIAGNOSTIC
#undef PARSER_DIAGNOSTIC
#undef LEXER_DIAGNOSTIC
#undef SOURCE_DIAGNOSTIC
#undef DIAGNOSTIC